@startuml DiagramaDeClasses
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 80


enum TipoUsuario {
  LEITOR
  BIBLIOTECARIO
}

enum StatusLeitor {
  ATIVO
  SUSPENSO
  PENDENTE_APROVACAO
}

enum StatusExemplar {
  DISPONIVEL
  EMPRESTADO
  RESERVADO
  MANUTENCAO
}

enum StatusReserva {
  PENDENTE
  ATENDIDA
  EXPIRADA
  CANCELADA
}

' --- Classes de Usuário ---
abstract class Usuario <<entity>> {
  - idUsuario: int
  - nome: String
  - email: String
  - login: String
  - senha: String
  - tipoUsuario: TipoUsuario
  + login(): boolean
}

class Leitor <<entity>> {
  - cpf: String
  - matricula: String
  - statusLeitor: StatusLeitor
  - dataCadastro: Date
  - dataFimSuspensao: Date
  + solicitarAutoCadastro(): void
  + consultarMeusEmprestimos(): List<Emprestimo>
  + solicitarRenovacao(idEmprestimo: int): void
  + solicitarReserva(idObra: int): void
  + visualizarHistoricoLeitura(): List<Emprestimo>
  + avaliarLivro(idObra: int, nota: int, comentario: String): void
}

class Bibliotecario <<entity>> {
  - registroFuncional: String
}

' --- Classes de Controle (BCE) ---
class GerenciadorAcervo <<control>> {
  + cadastrarObra(obra: Obra): void
  + editarObra(obra: Obra): void
  + removerObra(idObra: int): void
  + cadastrarExemplar(exemplar: Exemplar): void
  + editarExemplar(exemplar: Exemplar): void
  + removerExemplar(idExemplar: int): void
  + associarLocalizacao(idExemplar: int, idLocalizacao: int): void
  + cadastrarLocalizacao(loc: Localizacao): void
}

class GerenciadorEmprestimo <<control>> {
  + realizarEmprestimo(idLeitor: int, idExemplar: int): void
  + realizarDevolucao(idExemplar: int): void
  + renovarEmprestimo(idEmprestimo: int): void
  + registrarReserva(idLeitor: int, idObra: int): void
  + consultarHistoricoLeitor(idLeitor: int): List<Emprestimo>
}

class GerenciadorUsuario <<control>> {
  + cadastrarLeitor(leitor: Leitor): void
  + editarLeitor(leitor: Leitor): void
  + bloquearLeitor(idLeitor: int): void
  + desbloquearLeitor(idLeitor: int): void
  + aprovarLeitor(idLeitor: int): void
}

' --- Classes do Acervo ---
class Obra <<entity>> {
  - idObra: int
  - titulo: String
  - autor: String
  - isbn: String
  - editora: String
  - anoPublicacao: int
  - edicao: String
  - idioma: String
  - sinopse: String
  - urlCapa: String
  - paginas: int
  - categorias: List<Categoria>
  + buscarObras(filtros: String): List<Obra>
  + consultarDisponibilidade(): boolean
  + visualizarAvaliacoes(): List<Avaliacao>
}

class Categoria <<entity>> {
  - idCategoria: int
  - nome: String
}

class Exemplar <<entity>> {
  - idExemplar: int
  - codigoBarras: String
  - status: StatusExemplar
  - estadoConservacao: String
  - obra: Obra
  - localizacao: Localizacao
}

class Localizacao <<entity>> {
  - idLocalizacao: int
  - sala: String
  - estante: String
  - sessao: String
  - descricao: String
  + visualizarMapa(): String
}

' --- Classes Transacionais ---
class Emprestimo <<entity>> {
  - idEmprestimo: int
  - dataEmprestimo: Date
  - dataDevolucaoPrevista: Date
  - dataDevolucaoReal: Date
  - quantidadeRenovacoes: int
  - diasSuspensao: int
  - leitor: Leitor
  - exemplar: Exemplar
  + calcularMulta(): float
}

class Reserva <<entity>> {
  - idReserva: int
  - dataReserva: Date
  - statusReserva: StatusReserva
  - leitor: Leitor
  - obra: Obra
}

class Avaliacao <<entity>> {
  - idAvaliacao: int
  - nota: int
  - comentario: String
  - dataAvaliacao: Date
  - leitor: Leitor
  - obra: Obra
}

' --- Relacionamentos ---
Usuario <|-down- Leitor
Usuario <|-down- Bibliotecario

Obra " * " -right-> " * " Categoria : pertence a >
Obra " 1 " *-down-> " 1..* " Exemplar : possui >
Localizacao " 1 " o-- " 0..* " Exemplar : < fica em

Leitor " 1 " -down-> " 0..5 " Emprestimo : realiza >
Exemplar " 1 " <-left- " 0..* " Emprestimo : < referente a
Leitor " 1 " -right-> " 0..3 " Reserva : solicita >
Obra " 1 " <-left- " 0..* " Reserva : < referente a
Leitor " 1 " -up-> " 0..* " Avaliacao : escreve >
Obra " 1 " <-up- " 0..* " Avaliacao : < recebe

Bibliotecario -down-> GerenciadorAcervo : utiliza >
Bibliotecario -down-> GerenciadorEmprestimo : utiliza >
Bibliotecario -down-> GerenciadorUsuario : utiliza >

@enduml